---
// src/components/FreeEntry.astro
---

<section id="info-entradas" class="free-entry">
    <h2>Entrada Gratuita</h2>
    <div class="info-cards">
        <div class="card">
            <h3>📍 Ubicación</h3>
            <p>Mercat Vell, Mollet del Vallès</p>
            <a href="#ubicacion" class="card-link">Ver mapa</a>
        </div>
        <div class="card">
            <h3>⏰ Horario</h3>
            <p>27 de Marzo 2026: 17:00 - 01:00</p>
        </div>
        <div class="card">
            <h3>🎟️ Aforo</h3>
            <p>Acceso libre hasta completar aforo.<br />¡Llega pronto!</p>
        </div>
    </div>
</section>

<style>
    .free-entry {
        background: #0a0a0a;
        color: white;
        padding: 4rem 1rem;
        text-align: center;
    }
    .free-entry h2 {
        font-size: clamp(2rem, 6vw, 3rem);
        color: var(--color-accent);
        margin-bottom: 2.5rem;
        text-transform: uppercase;
    }
    .info-cards {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
    }
    .card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 320px;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(var(--color-accent-dark-rgb), 0.2);
    }
    .card h3 {
        color: var(--color-accent-light);
        margin-bottom: 1rem;
        font-size: 1.4rem;
    }
    .card p {
        color: var(--color-text);
        font-size: 1rem;
        line-height: 1.6;
    }
    .card-link {
        display: inline-block;
        margin-top: 1rem;
        color: var(--color-accent);
        text-decoration: underline;
        font-weight: bold;
    }
    .card-link:hover {
        color: var(--color-accent-light);
    }

    @media (max-width: 768px) {
        .info-cards {
            gap: 1rem;
        }
        .card {
            max-width: 90%;
            padding: 1.5rem;
        }
        .free-entry h2 {
            font-size: 2rem;
        }
    }
</style>

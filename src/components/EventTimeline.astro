---
// src/components/EventTimeline.astro;
---

<div class="timeline">
    <div class="timeline-item">
        <div class="time">17:00 - 19:00</div>
        <div class="artist">Deivit b2b Alberto Catena</div>
        <div class="genre">Groove</div>
    </div>

    <div class="timeline-item">
        <div class="time">19:00 - 20:30</div>
        <div class="artist">Inanna Dark</div>
        <div class="genre">Techno</div>
    </div>

    <div class="timeline-item">
        <div class="time">20:30 - 22:00</div>
        <div class="artist">Hottape</div>
        <div class="genre">Techno</div>
    </div>

    <div class="timeline-item">
        <div class="time">22:00 - 23:30</div>
        <div class="artist">DBlokk b2b Soveroon</div>
        <div class="genre">Hard Groove</div>
    </div>

        <div class="timeline-item">
        <div class="time">23:30 - 1:00</div>
        <div class="artist">Bapho999 b2b Diek</div>
        <div class="genre">Hard Techno</div>
    </div>
</div>

<style>
    .timeline {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem 2rem 3rem;
        position: relative;
    }

    .timeline::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 30px;
        width: 2px;
        background: linear-gradient(to bottom, transparent, var(--glass-border), var(--color-accent), var(--color-secondary-accent), transparent);
    }

    .timeline-item {
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        position: relative;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: -38px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        background: var(--color-surface);
        border: 2px solid var(--color-accent);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--color-accent);
        transition: all 0.3s ease;
        z-index: 2;
    }

    .timeline-item:hover {
        transform: translateX(10px);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .timeline-item:hover::before {
        background: var(--color-accent);
        box-shadow: 0 0 20px var(--color-accent), 0 0 40px var(--color-accent);
        transform: translateY(-50%) scale(1.3);
    }

    .time {
        color: var(--color-accent-light);
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 2px;
        margin-bottom: 0.8rem;
        display: inline-block;
        padding: 0.3rem 1rem;
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .artist {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--color-light);
        margin-bottom: 0.4rem;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .genre {
        color: var(--color-text-muted);
        font-weight: 400;
        font-size: 1.1rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    @media (max-width: 768px) {
        .timeline {
            padding-left: 2rem;
        }

        .timeline::before {
            left: 10px;
        }

        .timeline-item {
            padding: 1.5rem;
        }

        .timeline-item::before {
            left: -23px;
        }

        .artist {
            font-size: 1.6rem;
        }
    }
</style>
